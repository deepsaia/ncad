# irregular_house — a hand-authored irregular footprint with a MIX of sharp and rounded
# corners. Proves the spec format expresses arbitrary polygons (not just rect/L/T/U) with
# per-corner control: some vertices are plain [x,y] (sharp), some carry a corner_radius
# (rounded), and each rounded corner has a matching arc wall.
#
# Hexagon (CCW): (0,0) (10,0) (10,5) (6,8) (2,8) (0,5).
# Corners 2 (10,5) and 4 (2,8) are rounded (r=1.5); the rest are sharp.
# Tangent points + arc centers precomputed from the fillet geometry.

schema_version = 1
seed = 0
units = "m"

t = 0.2  # wall thickness

storeys = [
  {
    elevation = 0.0
    height = 3.0

    footprint = [
      [0, 0]
      [10, 0]
      { point = [10, 5], corner_radius = 1.5 }   # rounded
      [6, 8]
      { point = [2, 8], corner_radius = 1.5 }     # rounded
      [0, 5]
    ]

    walls = [
      # straight edges between tangent points (sharp corners use the vertex itself)
      { id = ext_0, start = [0, 0],        end = [10, 0],        thickness = ${t}
        openings = [
          { id = front_door, kind = door,   along = 0.3, width = 1.0, height = 2.1, sill = 0.0 }
          { id = win_0,      kind = window, along = 0.7, width = 1.2, height = 1.4, sill = 0.9 }
        ]
      }
      { id = ext_1, start = [10, 0],       end = [10, 4.25],     thickness = ${t} }
      { id = ext_2, start = [9.4, 5.45],   end = [6, 8],         thickness = ${t} }
      { id = ext_3, start = [2.803, 8.0],  end = [6, 8],         thickness = ${t} }
      { id = ext_4, start = [1.555, 7.332],end = [0, 5],         thickness = ${t} }
      { id = ext_5, start = [0, 5],        end = [0, 0],         thickness = ${t} }

      # arc walls at the two rounded corners
      { id = ext_arc_2, start = [10, 4.25],   end = [9.4, 5.45],   thickness = ${t}
        arc = { center = [8.5, 4.25], clockwise = false }
      }
      { id = ext_arc_4, start = [2.803, 8.0], end = [1.555, 7.332], thickness = ${t}
        arc = { center = [2.803, 6.5], clockwise = false }
      }
    ]

    rooms = [
      { id = main, polygon = [[0, 0], [10, 0], [10, 5], [6, 8], [2, 8], [0, 5]] }
    ]
  }
]

roof = {
  kind = flat
  thickness = 0.2
}
