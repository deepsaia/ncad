units = mm
metadata {
  description = "Mirrored bodies"
  tags = [ patterns-multibody, part ]
}
# Two body mirrors. `symmetric_bracket`: an L-shaped half-model whose upright sits ON the YZ
# plane (x = 0 edge), mirrored across YZ and fused (keep + merge) -> one symmetric T/U solid
# (planar contact at x = 0 means the union is a single valid solid). `mirror_pair`: a boss
# offset from the plane (x in [10, 20]), mirrored across YZ kept separate (merge = false) ->
# 2 addressable bodies pair/body/0 (original) + pair/body/1 (reflection at x in [-20, -10]).
parts {
  symmetric_bracket {
    profile = solid
    features = [
      # An L in the XY plane with one edge on x = 0 (the YZ plane): a 20x6 foot plus a
      # 6x20 upright, sharing the x = 0 edge.
      { id = l_sk, op = sketch, plane = XY,
        elements = [ { id = l, type = polygon,
          points = [ [ 0, 0 ], [ 20, 0 ], [ 20, 6 ], [ 6, 6 ], [ 6, 20 ], [ 0, 20 ] ] } ] }
      { id = arm, op = extrude, profile = l_sk, distance = 8 }
      { id = sym, op = mirror, plane = YZ, keep = true, merge = true }
    ]
  }
  mirror_pair {
    profile = solid
    features = [
      # A boss offset from the plane (x in [10, 20]); mirroring across YZ keeps it separate.
      { id = boss_sk, op = sketch, plane = XY,
        elements = [ { id = r, type = polygon,
          points = [ [ 10, -4 ], [ 20, -4 ], [ 20, 4 ], [ 10, 4 ] ] } ] }
      { id = boss, op = extrude, profile = boss_sk, distance = 6 }
      { id = pair, op = mirror, plane = YZ, keep = true, merge = false }
    ]
  }
}
