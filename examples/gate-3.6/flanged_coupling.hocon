units = mm
metadata {
  description = "Flanged coupling"
  tags = [ g3_6, part ]
}
# Phase 3 capstone: a flanged shaft coupling composing the whole phase in one believable part.
# An aluminium flange with a bolt-circle of 6 holes (a cutter placed at the bolt radius via
# `circle at`, circular-patterned, then boolean-cut) and a central bore, plus a steel hub kept
# as its own body (boolean union merge=false, feature material override). The half-coupling is
# then mirrored across its base plane into a symmetric two-flange coupling. Result: 4 addressable
# bodies (2 aluminium flanges + 2 steel hubs) with per-body derived mass and an assembly total.
materials {
  # inline: nudge aluminium density (demonstrates inline > seed).
  aluminium_6061 { physical { density = 2710 } }
}
parts {
  flanged_coupling {
    profile = solid
    material = "aluminium_6061"
    features = [
      { id = flange_sk, op = sketch, plane = XY, elements = [ { id = c, type = circle, d = 60 } ] }
      { id = flange, op = extrude, profile = flange_sk, distance = 8 }
      # One bolt-hole cutter placed on the bolt-circle (r = 22) via `circle at`, then patterned
      # 6 times around the axis (merge = false -> 6 cutter bodies), then cut from the flange.
      { id = bolt_sk, op = sketch, plane = XY, elements = [ { id = c, type = circle, d = 6, at = [ 22, 0 ] } ] }
      { id = bolt, op = extrude, profile = bolt_sk, distance = 8 }
      { id = ring, op = pattern, kind = circular, count = 6, merge = false }
      { id = drilled, op = boolean, operation = cut, target = flange, tools = [ ring ] }
      # Central bore through the flange.
      { id = bore_sk, op = sketch, plane = XY, elements = [ { id = c, type = circle, d = 12 } ] }
      { id = bore, op = extrude, profile = bore_sk, distance = 8 }
      { id = holed, op = boolean, operation = cut, target = drilled, tool = bore }
      # Steel hub stub on the flange face, bored through, kept as its own body.
      { id = hub_sk, op = sketch, plane = XY, plane_offset = 8, elements = [ { id = c, type = circle, d = 24 } ] }
      { id = hub, op = extrude, profile = hub_sk, distance = 20, material = "steel_1018" }
      { id = hub_bore_sk, op = sketch, plane = XY, plane_offset = 8, elements = [ { id = c, type = circle, d = 12 } ] }
      { id = hub_bore, op = extrude, profile = hub_bore_sk, distance = 20 }
      { id = hub_drilled, op = boolean, operation = cut, target = hub, tool = hub_bore, material = "steel_1018" }
      # Flange + hub as two addressable bodies (aluminium flange, steel hub).
      { id = coupling, op = boolean, operation = union, merge = false, target = holed, tool = hub_drilled }
      # Mirror the half-coupling across its base plane into a symmetric coupling (4 bodies).
      { id = symmetric, op = mirror, plane = XY, keep = true, merge = false }
    ]
  }
}
