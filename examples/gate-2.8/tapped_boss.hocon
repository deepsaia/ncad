units = mm
metadata {
  description = "Tapped boss"
  tags = [ g2_8, part ]
}
# A boss with an M6 tapped hole: sized to the tap-drill diameter (5.0) via size + fit, with
# a cosmetic thread = M6 tag (metadata, no geometry change). Round-trips to STEP.
parts {
  tapped_boss {
    profile = solid
    features = [
      { id = boss_sk, op = sketch, plane = XY,
        elements = [ { id = sq, type = rectangle, w = 20, h = 20 } ] }
      { id = boss, op = extrude, profile = boss_sk, distance = 15 }
      { id = tap, op = hole, plane = XY, positions = [ [ 10, 10 ] ],
        size = M6, fit = tapped, depth = 12, thread = M6 }
    ]
  }
}
