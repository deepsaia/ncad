schema_version = 2
units = mm
# Exercises the 2.1 end-condition vocabulary: a base plate (blind), a symmetric drafted
# boss centered on its own sketch plane, and a through-all pocket cut clean through the
# plate. Builds deterministically and round-trips to STEP (bucket 2.0).
parameters { plate_t = 8, boss_h = 20, draft_deg = 3 }
parts {
  end_conditions {
    profile = solid
    features = [
      { id = base_sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = 60, h = 40 } ] }
      { id = plate, op = extrude, profile = base_sk, end = blind, distance = "${plate_t}" }
      { id = boss_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 16 } ] }
      { id = boss, op = extrude, profile = boss_sk, end = symmetric,
        distance = "${boss_h}", draft = "${draft_deg}" }
      { id = hole_sk, op = sketch, plane = XY,
        elements = [ { id = h, type = circle, d = 6 } ] }
      { id = drill, op = pocket, target = plate, profile = hole_sk, end = through_all }
    ]
  }
}
