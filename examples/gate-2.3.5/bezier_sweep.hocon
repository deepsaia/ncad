units = mm
metadata {
  description = "Bezier sweep"
  tags = [ g2_3_5, part ]
}
# An open BEZIER path (control points p0..p3) swept with a small circular profile. Proves
# the "smooth sweep path for free" goal of the spline bucket. Single-path sweep; round-trips
# to STEP (bucket 2.0).
parts {
  bezier_sweep {
    profile = solid
    features = [
      { id = path_sk, op = sketch, plane = XZ, open = true,
        entities = [
          { id = p0, type = point, at = [ 0, 0 ] }
          { id = p1, type = point, at = [ 0, 20 ] }
          { id = p2, type = point, at = [ 20, 20 ] }
          { id = p3, type = point, at = [ 20, 0 ] }
          { id = curve, type = bezier, points = [ p0, p1, p2, p3 ] }
        ]
        constraints = [ { type = fix, of = p0 }, { type = fix, of = p1 },
          { type = fix, of = p2 }, { type = fix, of = p3 } ] }
      { id = prof_sk, op = sketch, plane = XY,
        elements = [ { id = circ, type = circle, d = 3 } ] }
      # is_frenet keeps a coherent profile frame around the bezier's curving direction;
      # OCCT's default (corrected-frame) transport fails to close the solid on this path.
      { id = tube, op = sweep, profile = prof_sk, path = path_sk, is_frenet = true }
    ]
  }
}
