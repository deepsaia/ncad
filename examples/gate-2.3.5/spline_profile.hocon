units = mm
metadata {
  description = "Spline profile"
  tags = [ g2_3_5, part ]
}
# A closed profile whose top edge is an INTERPOLATED spline bulging up through (2,3),
# closed by three straight lines back to the start. Extruded into a solid. Proves a
# closed-loop spline >> face >> solid, and round-trips to STEP (bucket 2.0).
parts {
  spline_profile {
    profile = solid
    features = [
      { id = prof_sk, op = sketch, plane = XY,
        entities = [
          { id = p0, type = point, at = [ 0, 0 ] }
          { id = pm, type = point, at = [ 2, 3 ] }
          { id = p1, type = point, at = [ 4, 0 ] }
          { id = p2, type = point, at = [ 4, -2 ] }
          { id = p3, type = point, at = [ 0, -2 ] }
          { id = top, type = interpolated, points = [ p0, pm, p1 ] }
          { id = right, type = line, p1 = p1, p2 = p2 }
          { id = bottom, type = line, p1 = p2, p2 = p3 }
          { id = left, type = line, p1 = p3, p2 = p0 }
        ]
        constraints = [ { type = fix, of = p0 }, { type = fix, of = pm },
          { type = fix, of = p1 }, { type = fix, of = p2 }, { type = fix, of = p3 } ] }
      { id = pad, op = extrude, profile = prof_sk, distance = 5 }
    ]
  }
}
