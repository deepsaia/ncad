schema_version = 2
units = mm
# A real single-cylinder crank-slider (see docs/images/crank-slider-reference.jpg): a flywheel at
# the bottom carries a crank pin; a connecting rod links it to a piston sliding in a cylinder shell
# up top. NO base plate, just the linkage (as in the reference).
#
# Connectors use the DIRECT-COORDINATE form (`at_point` + `axis`): every mate point is named by its
# local coordinate, so it does not depend on hunting a face by area (which breaks whenever a boolean
# reshapes a face). Depth (z) layout so parts nest instead of colliding: the rod, piston, wrist pin
# and crank pin are coplanar on z = 0; the flywheel disc sits BEHIND at z < 0 (its crank-pin boss
# bridges forward to z = 0), and the cylinder + main bearing stand clear. Pins run along Z; the
# piston slides along +Y. Rest pose (crank angle 0, pin on +X): R = 20 throw, L = 70 rod, wrist y=67.
metadata {
  description = "Single-cylinder crank-slider: flywheel, crank pin, connecting rod, piston, cylinder"
  tags = [ crank_slider, mechanism, engine ]
}
parts {
  flywheel { profile = solid, material = steel_4140,
    connectors = [
      { id = hub, at_point = [ 0, 0, 0 ], axis = [ 0, 0, 1 ] }
      { id = pin, at_point = [ 20, 0, 0 ], axis = [ 0, 0, 1 ] }
    ],
    features = [
      { id = disc_sk, op = sketch, plane = XY, plane_offset = -14,
        elements = [ { id = c, type = circle, d = 100 } ] }
      { id = disc, op = extrude, profile = disc_sk, distance = 10 }
      { id = pinboss_sk, op = sketch, plane = XY, plane_offset = -14,
        elements = [ { id = c, type = circle, d = 10, at = [ 20, 0 ] } ] }
      { id = pinboss, op = extrude, profile = pinboss_sk, distance = 16 }
      { id = withpin, op = boolean, operation = union, target = disc, tool = pinboss }
      { id = lighten, op = hole, plane = XY, plane_offset = -14,
        positions = [ [ 32, 0 ], [ -32, 0 ], [ 0, 32 ], [ 0, -32 ] ], diameter = 22,
        through = true }
    ] }
  rod { profile = solid, material = steel_4140,
    connectors = [
      { id = big, at_point = [ 20, 0, 0 ], axis = [ 0, 0, 1 ] }
      { id = small, at_point = [ 0, 67, 0 ], axis = [ 0, 0, 1 ] }
    ],
    features = [
      { id = bigeye_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 14, at = [ 20, 0 ] } ] }
      { id = bigeye, op = extrude, profile = bigeye_sk, distance = 6 }
      { id = smalleye_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 12, at = [ 0, 67 ] } ] }
      { id = smalleye, op = extrude, profile = smalleye_sk, distance = 6 }
      { id = eyes, op = boolean, operation = union, target = bigeye, tool = smalleye }
      { id = shaft_sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = 8, h = 62, at = [ 10, 33.5 ] } ] }
      { id = shaft, op = extrude, profile = shaft_sk, distance = 6 }
      { id = rod_solid, op = boolean, operation = union, target = eyes, tool = shaft }
      { id = bigbore_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 5, at = [ 20, 0 ] } ] }
      { id = bigbore_tool, op = extrude, profile = bigbore_sk, end = symmetric, distance = 20 }
      { id = withbig, op = boolean, operation = cut, target = rod_solid, tool = bigbore_tool }
      { id = smallbore_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 4, at = [ 0, 67 ] } ] }
      { id = smallbore_tool, op = extrude, profile = smallbore_sk, end = symmetric, distance = 20 }
      { id = bored, op = boolean, operation = cut, target = withbig, tool = smallbore_tool }
    ] }
  piston { profile = solid, material = aluminium_6061,
    connectors = [
      { id = crown, at_point = [ 0, 67, 0 ], axis = [ 0, 1, 0 ] }
      { id = wrist, at_point = [ 0, 67, 0 ], axis = [ 0, 0, 1 ] }
    ],
    features = [
      { id = slug_sk, op = sketch, plane = XZ, plane_offset = -79,
        elements = [ { id = c, type = circle, d = 30 } ] }
      { id = slug, op = extrude, profile = slug_sk, distance = 24 }
      { id = wrist_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 4, at = [ 0, 67 ] } ] }
      { id = wrist_tool, op = extrude, profile = wrist_sk, end = symmetric, distance = 40 }
      { id = bored, op = boolean, operation = cut, target = slug, tool = wrist_tool }
    ] }
  block { profile = solid, material = steel_1018,
    connectors = [
      { id = bore, at_point = [ 0, 67, 0 ], axis = [ 0, 1, 0 ] }
      { id = main, at_point = [ 0, 0, 0 ], axis = [ 0, 0, 1 ] }
    ],
    features = [
      { id = tube_sk, op = sketch, plane = XZ, plane_offset = -55,
        elements = [ { id = c, type = circle, d = 44 } ] }
      { id = tube, op = extrude, profile = tube_sk, distance = 80 }
      { id = bore_sk, op = sketch, plane = XZ, plane_offset = -55,
        elements = [ { id = c, type = circle, d = 31 } ] }
      { id = bore_tool, op = extrude, profile = bore_sk, distance = 80 }
      { id = shell, op = boolean, operation = cut, target = tube, tool = bore_tool }
      { id = arm_sk, op = sketch, plane = XY, plane_offset = -19,
        elements = [ { id = r, type = rectangle, w = 16, h = 70, at = [ 0, 5 ] } ] }
      { id = arm, op = extrude, profile = arm_sk, distance = 8 }
      { id = witharm, op = boolean, operation = union, target = shell, tool = arm }
    ] }
}
