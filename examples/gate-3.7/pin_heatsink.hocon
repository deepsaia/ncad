units = mm
metadata {
  description = "Pin heatsink"
  tags = [ g3_7, part ]
}
# A pin-grid heat sink: a base pad with an upstanding pin, FILL-patterned across the pad's top
# face into a field of cooling pins on one base. A real, recognizable part exercising the 3.7
# fill pattern (grid over a face at a spacing). The running solid (pad + one pin) is filled and
# merged: the overlapping pad copies fuse into a single base, leaving the pin array standing on
# it. (Fill patterns the running solid over one of its own faces; a separate cutter over a
# distinct part's face is feature-pattern, Phase 4.)
parts {
  pin_heatsink {
    profile = solid
    material = aluminium_6061
    features = [
      { id = pad_sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = 80, h = 50 } ] }
      { id = pad, op = extrude, profile = pad_sk, distance = 3 }
      { id = pin_sk, op = sketch, plane = XY, plane_offset = 3,
        elements = [ { id = c, type = circle, d = 4 } ] }
      { id = pin, op = extrude, profile = pin_sk, distance = 12 }
      { id = base, op = boolean, operation = union, target = pad, tool = pin }
      { id = field, op = pattern, kind = fill,
        region = "select faces where normal_z > 0.9 and area > 100", spacing = 12,
        merge = true }
    ]
  }
}
