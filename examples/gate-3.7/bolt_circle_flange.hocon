schema_version = 2
units = mm
metadata {
  description = "Bolt circle flange"
  tags = [ g3_7, part ]
}
# A pipe flange with a bolt circle: a round plate, a central bore, and 8 bolt holes on a bolt
# circle with TWO omitted (a common clocking/keyway gap). A real, recognizable part that
# exercises the 3.7 circular pattern + per-instance suppress: a single bolt-hole cutter is
# circular-patterned into 8 positions, ordinals 0 and 4 suppressed, then all are cut.
parts {
  bolt_circle_flange {
    profile = solid
    material = steel_1018
    features = [
      # Flange plate: a d120 disk, 12mm thick.
      { id = plate_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 120 } ] }
      { id = plate, op = extrude, profile = plate_sk, distance = 12 }
      # Central bore d50 through the plate.
      { id = bore_sk, op = sketch, plane = XY, elements = [ { id = b, type = circle, d = 50 } ] }
      { id = bore_tool, op = extrude, profile = bore_sk, distance = 12 }
      { id = bored, op = boolean, operation = cut, target = plate, tool = bore_tool }
      # One bolt-hole cutter placed on the bolt circle (radius 45), circular-patterned to 8
      # about the Z axis, kept separate as the cut tools; ordinals 0 and 4 suppressed.
      { id = hole_sk, op = sketch, plane = XY,
        elements = [ { id = h, type = circle, d = 11, at = [ 45, 0 ] } ] }
      { id = hole_tool, op = extrude, profile = hole_sk, distance = 12 }
      { id = holes, op = pattern, kind = circular, count = 8,
        axis = { point = [ 0, 0, 0 ], dir = [ 0, 0, 1 ] }, merge = false,
        suppress = [ 0, 4 ] }
      { id = drilled, op = boolean, operation = cut, target = bored, tool = holes }
    ]
  }
}
