# Phase 5 CAPSTONE (bucket 5.6): a two-part mated assembly with one revolute joint. The lever's hub
# is pinned to the bracket's pivot axis by a revolute (1 rotational DoF free). The assembly exports
# as a structured STEP AP242 (named + colored components, an assembly tree that opens in FreeCAD),
# reports its BOM + roll-up mass, and its interference is checked (the coaxial pin reads correctly).
units = mm
metadata {
  description = "Mated bracket assembly"
  tags = [ g5_6, assembly ]
}
assembly {
  instances = [
    { id = base, file = "mated_bracket.hocon", part = bracket, lock = true }
    { id = arm, file = "mated_bracket.hocon", part = lever }
  ]
  joints = [
    { id = j1, type = revolute, between = [
      { instance = base, connector = pivot },
      { instance = arm, connector = hub } ] }
  ]
}
