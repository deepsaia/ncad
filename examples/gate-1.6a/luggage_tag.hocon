schema_version = 2
units = mm
# A luggage tag: an elliptical tag body with a round strap hole near one end. A real,
# recognizable part that exercises the 1.6a sketch entities end to end and round-trips to
# STEP:
#   - the tag OUTLINE is a full `ellipse` (major radius 30, minor radius 18), a closed loop
#     >> face >> extruded 3mm plate. The ellipse is point-defined (center + major-axis-end
#     points carry the solver DoF; the curve is derived by the kernel via Edge.make_ellipse,
#     since py-slvs has no ellipse primitive).
#   - the STRAP HOLE is a full circle built from an `arc_polar` top semicircle plus a plain
#     arc bottom semicircle that reuses the arc_polar's generated endpoint ids (hole_top/start,
#     hole_top/end). arc_polar emits those endpoints as fixed primitives, so the hole sketch is
#     well-constrained by construction (dof 0) with only its center pinned. The hole is
#     extruded and boolean-cut through the tag.
parts {
  luggage_tag {
    profile = solid
    material = aluminium_6061
    features = [
      { id = body_sk, op = sketch, plane = XY,
        entities = [
          { id = c, type = point, at = [ 0, 0 ] }
          { id = m, type = point, at = [ 30, 0 ] }
          { id = outline, type = ellipse, center = c, major_axis_end = m, minor_radius = 18 }
        ]
        constraints = [ { type = fix, of = c }, { type = fix, of = m } ] }
      { id = body, op = extrude, profile = body_sk, distance = 3 }
      { id = hole_sk, op = sketch, plane = XY,
        entities = [
          { id = hc, type = point, at = [ 22, 0 ] }
          { id = hole_top, type = arc_polar, center = hc, radius = 4, start_angle = 0,
            sweep = 180 }
          { id = hole_bot, type = arc, center = hc, start = "hole_top/end",
            end = "hole_top/start" }
        ]
        constraints = [ { type = fix, of = hc } ] }
      { id = hole_tool, op = extrude, profile = hole_sk, distance = 3 }
      { id = strap_hole, op = boolean, operation = cut, target = body, tool = hole_tool }
    ]
  }
}
