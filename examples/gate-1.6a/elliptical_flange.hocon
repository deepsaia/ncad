schema_version = 2
units = mm
metadata {
  description = "Elliptical flange"
  tags = [ g1_6a, part ]
}
# An elliptical flange: an ellipse outer profile extruded to a plate, then a round hub
# unioned on top. Proves ellipse (closed loop >> face >> solid) and the arc_polar authoring
# sugar end to end, round-tripping to STEP. The hub is a full circle formed by an arc_polar
# top semicircle plus a plain arc bottom semicircle that reuses the arc_polar's generated
# endpoint ids (top/start, top/end). arc_polar emits those endpoints as fixed primitives, so
# the hub sketch is well-constrained by construction (dof 0) with only the center pinned.
parts {
  elliptical_flange {
    profile = solid
    features = [
      { id = base_sk, op = sketch, plane = XY,
        entities = [
          { id = c, type = point, at = [ 0, 0 ] }
          { id = m, type = point, at = [ 20, 0 ] }
          { id = ell, type = ellipse, center = c, major_axis_end = m, minor_radius = 10 }
        ]
        constraints = [ { type = fix, of = c }, { type = fix, of = m } ] }
      { id = plate, op = extrude, profile = base_sk, distance = 4 }
      { id = boss_sk, op = sketch, plane = XY, plane_offset = 4,
        entities = [
          { id = bc, type = point, at = [ 0, 0 ] }
          { id = top, type = arc_polar, center = bc, radius = 6, start_angle = 0, sweep = 180 }
          { id = bot, type = arc, center = bc, start = "top/end", end = "top/start" }
        ]
        constraints = [ { type = fix, of = bc } ] }
      { id = boss_solid, op = extrude, profile = boss_sk, distance = 3 }
      { id = boss, op = boolean, operation = union, target = plate, tool = boss_solid }
    ]
  }
}
