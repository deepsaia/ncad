units = mm
metadata {
  description = "Geared screw"
  tags = [ g5_4b, part ]
}
parts {
  # A block with a central bore (a plate with a circular cut): the bore cylinder is the bolt's
  # target connector. Grounded; the bolt screws into it.
  block { profile = solid,
    connectors = [ { id = bore, at = "select faces where type = 'cylinder'" } ],
    features = [
      { id = sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = 30, h = 30 } ] }
      { id = ext, op = extrude, profile = sk, distance = 20 }
      { id = hole_sk, op = sketch, plane = XY, elements = [ { id = c, type = circle, d = 8 } ] }
      { id = hole, op = extrude, profile = hole_sk, distance = 20, cut = true }
    ] }
  # A shaft post (a cylinder); its side face is the axis connector a gear mounts on. Instanced twice
  # at offset placements so the two gears sit on parallel axes (a real mesh, not coaxial).
  shaft { profile = solid,
    connectors = [ { id = axis, at = "select faces where type = 'cylinder'" } ],
    features = [
      { id = sk, op = sketch, plane = XY, elements = [ { id = c, type = circle, d = 6 } ] }
      { id = ext, op = extrude, profile = sk, distance = 16 }
    ] }
  # A gear disk with a central cylinder-axis connector (mounts on a shaft via a revolute).
  gear { profile = solid,
    connectors = [ { id = hub, at = "select faces where type = 'cylinder'" } ],
    features = [
      { id = sk, op = sketch, plane = XY, elements = [ { id = c, type = circle, d = 20 } ] }
      { id = ext, op = extrude, profile = sk, distance = 5 }
    ] }
  # A bolt with a cylindrical shaft; a screw joint drives it into the block's bore. The shank is
  # d=6 (the bore is d=8) so there is clearance: coincident-diameter walls would z-fight in render.
  bolt { profile = solid,
    connectors = [ { id = shank, at = "select faces where type = 'cylinder'" } ],
    features = [
      { id = sk, op = sketch, plane = XY, elements = [ { id = c, type = circle, d = 6 } ] }
      { id = ext, op = extrude, profile = sk, distance = 30 }
    ] }
}
