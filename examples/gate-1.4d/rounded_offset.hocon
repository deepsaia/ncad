schema_version = 1
units = mm
# A rectangular loop offset inward with ROUND corners, a smaller rounded-rectangle face.
# Exercises loop_offset corner=round (tangent fillet arcs of radius = |distance|).
parameters { w = 40, h = 24, inset = 5, t = 5 }
parts {
  rounded_offset {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        entities = [
          { id = bl, type = point, at = [ 0, 0 ] }
          { id = br, type = point, at = [ 40, 0 ] }
          { id = tr, type = point, at = [ 40, 24 ] }
          { id = tl, type = point, at = [ 0, 24 ] }
          { id = bottom, type = line, p1 = bl, p2 = br }
          { id = right, type = line, p1 = br, p2 = tr }
          { id = top, type = line, p1 = tr, p2 = tl }
          { id = left, type = line, p1 = tl, p2 = bl }
        ]
        modify = [
          { id = inner, op = loop_offset,
            entities = [ bottom, right, top, left ], distance = -5, corner = round }
        ] }
      { id = pad, op = extrude, profile = sk, distance = "${t}" }
    ]
  }
}
