units = mm
metadata {
  description = "Constrained lbracket"
  tags = [ g1_1, part ]
}
# An L-shaped profile authored as 6 constrained line segments. Horizontal/vertical
# constraints make the corners square; distances set each leg. This shape cannot be a
# centered-primitive sketch, it needs the constraint solver.
parameters { long = 80, tall = 60, arm = 20, t = 12 }
parts {
  constrained_lbracket {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        entities = [
          { id = a, type = point, at = [ 0, 0 ] }
          { id = b, type = point, at = [ 78, 1 ] }
          { id = c, type = point, at = [ 79, 19 ] }
          { id = d, type = point, at = [ 21, 20 ] }
          { id = e, type = point, at = [ 20, 58 ] }
          { id = f, type = point, at = [ 1, 59 ] }
          { id = l0, type = line, p1 = a, p2 = b }
          { id = l1, type = line, p1 = b, p2 = c }
          { id = l2, type = line, p1 = c, p2 = d }
          { id = l3, type = line, p1 = d, p2 = e }
          { id = l4, type = line, p1 = e, p2 = f }
          { id = l5, type = line, p1 = f, p2 = a }
        ]
        constraints = [
          { type = horizontal, of = l0 }
          { type = vertical, of = l1 }
          { type = horizontal, of = l2 }
          { type = vertical, of = l3 }
          { type = horizontal, of = l4 }
          { type = vertical, of = l5 }
          { type = distance, points = [ a, b ], value = "${long}" }
          { type = distance, points = [ b, c ], value = "${arm}" }
          { type = distance, points = [ a, f ], value = "${tall}" }
          { type = distance, points = [ e, f ], value = "${arm}" }
        ] }
      { id = pad, op = extrude, profile = sk, distance = "${t}" }
    ]
  }
}
