schema_version = 2
units = mm
# A 2-body part: two disjoint extruded blocks kept as SEPARATE bodies by a keep-separate
# boolean union (merge = false). Proves the Phase 3 multibody foundation - each body is
# addressable with its own id and volume, and the part round-trips to STEP as a 2-solid
# assembly. block_b sits clear of block_a (its rectangle is authored around x = 40) so the
# two are visibly distinct bodies.
parts {
  two_body_bracket {
    profile = solid
    features = [
      { id = a_sk, op = sketch, plane = XY,
        elements = [ { id = ra, type = rectangle, w = 20, h = 20 } ] }
      { id = block_a, op = extrude, profile = a_sk, distance = 10 }
      { id = b_sk, op = sketch, plane = XY,
        elements = [ { id = rb, type = polygon,
                       points = [ [ 30, -7 ], [ 44, -7 ], [ 44, 7 ], [ 30, 7 ] ] } ] }
      { id = block_b, op = extrude, profile = b_sk, distance = 24 }
      # Keep the two blocks as separate bodies (do not fuse): merge = false yields a 2-body
      # result, each input body keeping its identity.
      { id = pair, op = boolean, operation = union, merge = false,
        target = block_a, tool = block_b }
    ]
  }
}
