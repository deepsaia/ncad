schema_version = 2
units = mm
# A plain block, sketched and extruded, exported to STEP. The gate for bucket 2.0: a built
# solid round-trips to valid STEP (re-imports as a solid with matching volume). glb is for
# viewing; STEP is the exact-B-rep CAD-interchange output (design section 14).
parts {
  step_block {
    profile = solid
    features = [
      {
        id = sk
        op = sketch
        plane = XY
        elements = [ { id = r, type = rectangle, w = 40, h = 24 } ]
      }
      { id = pad, op = extrude, profile = sk, distance = 10 }
    ]
  }
}
