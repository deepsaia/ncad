units = mm
metadata {
  description = "Mirrored profile"
  tags = [ g1_4b, part ]
}
# A symmetric arrowhead built by mirroring a half-profile across the Y axis. The authored
# half is an open chain from the top of the centreline, out to a right barb, in to a
# waist, and down to the apex at the origin. Mirroring the three right-side segments
# across the apex->top axis welds the two halves (the on-axis apex and top points map
# onto themselves) into one closed symmetric loop, which extrudes to a solid.
parameters { height = 40, barb = 15, waist = 6, t = 6 }
parts {
  mirrored_profile {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        entities = [
          { id = apex, type = point, at = [ 0, 0 ] }
          { id = top, type = point, at = [ 0, 40 ] }
          { id = barb, type = point, at = [ 15, 25 ] }
          { id = waist, type = point, at = [ 6, 20 ] }
          { id = e0, type = line, p1 = top, p2 = barb }
          { id = e1, type = line, p1 = barb, p2 = waist }
          { id = e2, type = line, p1 = waist, p2 = apex }
        ]
        constraints = [ { type = fix, of = barb }, { type = fix, of = waist } ]
        transforms = [
          { id = mir, op = mirror, sources = [ e0, e1, e2 ],
            axis = { p1 = apex, p2 = top } }
        ] }
      { id = pad, op = extrude, profile = sk, distance = "${t}" }
    ]
  }
}
