# A motion study (a first-class document kind, like part / assembly): it drives a
# referenced assembly and produces a trajectory. Here the four-bar's input crank turns a full
# revolution; the OndselSolver multibody engine (via pyondsel) converges the CLOSED LOOP at each
# step and the output rocker sweeps its bounded arc, from the declared joints + one driver, with NO
# per-mechanism formula. One assembly can back several motion studies (different driver / range).
metadata {
  description = "Four-bar motion study: drive the input crank one revolution"
  tags = [ four_bar, motion ]
}
motion {
  assembly = "four_bar.asm.hocon"
  driver = { joint = pinA, from = 0, to = 360, steps = 72 }
}
