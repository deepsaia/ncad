schema_version = 1
units = mm
# A slotted bar: a long block with a central pocket slot, driven by a `wall` expression
# so the slot tracks the bar size. Small and quick to rebuild, so it shows the
# same-document-is-deterministic half of the gate as clearly as the incremental half.
parameters {
  length = 100
  bar_w = 24
  bar_t = 12
  wall = 4
  slot_l = "${length} - 4 * ${wall}"
  slot_w = "${bar_w} - 2 * ${wall}"
}
parts {
  param_bar {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = "${length}", h = "${bar_w}" } ] }
      { id = bar, op = extrude, profile = sk, distance = "${bar_t}" }
      { id = slot_sk, op = sketch, plane = XY,
        elements = [ { id = sr, type = rectangle, w = "${slot_l}", h = "${slot_w}" } ] }
      { id = slot, op = pocket, target = bar, profile = slot_sk, distance = "${wall}" }
      { id = ease, op = fillet, radius = "${wall} / 2",
        edges = "select edges where created_by='bar' and orientation='vertical'" }
    ]
  }
}
