schema_version = 1
units = mm
metadata {
  description = "Param plate"
  tags = [ g0_4, part ]
}
# A fully parameter-driven plate: edit any value and rebuild. Only the dirty suffix
# re-executes (bucket 0.4). E.g. change `thickness` and the sketch is a cache hit,
# while the pad and holes re-run; change `hole_d` and the sketch + pad stay cached.
parameters {
  width = 90
  depth = 60
  thickness = 10
  hole_d = 6
  margin = "${hole_d} * 2"
  fillet_r = 4
}
parts {
  param_plate {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = "${width}", h = "${depth}" } ] }
      { id = pad, op = extrude, profile = sk, distance = "${thickness}" }
      { id = holes, op = hole, on = "pad.cap(+Z)", diameter = "${hole_d}", depth = "${thickness}",
        positions = [
          [ "${margin} - ${width}/2", "${margin} - ${depth}/2" ],
          [ "${width}/2 - ${margin}", "${margin} - ${depth}/2" ],
          [ "${margin} - ${width}/2", "${depth}/2 - ${margin}" ],
          [ "${width}/2 - ${margin}", "${depth}/2 - ${margin}" ]
        ] }
      { id = soften, op = fillet, radius = "${fillet_r}",
        edges = "select edges where created_by='pad' and orientation='vertical'" }
    ]
  }
}
