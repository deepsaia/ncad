units = mm
metadata {
  description = "Control knob"
  tags = [ g2_10, part ]
}
# A control knob: a cylindrical body with the engraved label "ON" wrapped onto its curved
# side wall, and a chamfered top edge. A real, recognizable part exercising the 2.10
# curved-surface wrap (engrave on a cylinder) with an assignable font (falls back to the
# default if the font is absent on the host) and a vertex-free edge chamfer.
parts {
  control_knob {
    profile = solid
    material = aluminium_6061
    features = [
      { id = body_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 30 } ] }
      { id = body, op = extrude, profile = body_sk, distance = 20 }
      # Engrave "ON" into the curved side wall (font Arial; falls back to default if missing).
      { id = label, op = wrap, on = "select faces where type = 'cylinder'",
        text = "ON", font = Arial, font_size = 6, depth = 0.8, mode = engrave }
      # Bevel the top rim for grip comfort.
      { id = rim, op = chamfer, edges = top, distance = 1.5 }
    ]
  }
}
