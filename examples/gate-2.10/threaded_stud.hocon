schema_version = 2
units = mm
# A threaded stud: a plain cylindrical rod with a MODELED (real helical) M10 thread cut over
# its length. Shows the explicit modeled-thread opt-in (`modeled = true`), which sweeps a V
# profile along a helix on the clean origin-axis cylinder (the geometry pro tools reserve for
# STL/3D-print/render; cosmetic callouts are the default elsewhere, see hex_bolt).
parts {
  threaded_stud {
    profile = solid
    material = steel_1018
    features = [
      { id = rod_sk, op = sketch, plane = XY,
        elements = [ { id = c, type = circle, d = 10 } ] }
      { id = rod, op = extrude, profile = rod_sk, distance = 26 }
      # Modeled M10 thread (coarse pitch 1.5) over the rod, about the origin Z axis.
      { id = thread, op = thread, size = M10, length = 24, modeled = true,
        axis = { point = [ 0, 0, 0 ], dir = [ 0, 0, 1 ] } }
    ]
  }
}
