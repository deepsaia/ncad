schema_version = 2
units = mm
metadata {
  description = "Shelf bracket"
  tags = [ g2_10, part ]
}
# A shelf bracket: the familiar L-shaped wall shelf support with a triangular gusset. A real,
# recognizable part that exercises the 2.10 features together: a horizontal arm + a vertical
# wall plate joined into an L, a gusset rib bracing the reentrant corner, and a DATUM PLANE
# offset from the wall plate that positions a mounting-hole reference.
parts {
  shelf_bracket {
    profile = solid
    material = steel_1018
    features = [
      # Wall plate: a vertical slab in the YZ plane region (60 tall, 40 wide, 6 thick).
      { id = wall_sk, op = sketch, plane = YZ,
        elements = [ { id = r, type = rectangle, w = 40, h = 60 } ] }
      { id = wall, op = extrude, profile = wall_sk, distance = 6 }
      # Shelf arm: a horizontal slab growing out from the wall base (50 out, 40 wide, 6 thick).
      { id = arm_sk, op = sketch, plane = XY,
        elements = [ { id = ra, type = rectangle, w = 50, h = 40 } ] }
      { id = arm_ext, op = extrude, profile = arm_sk, distance = 6 }
      { id = ell, op = boolean, operation = union, target = wall, tool = arm_ext }
      # A diagonal gusset rib in the XZ plane, grown UNTIL it meets the arm + wall (auto-
      # trimmed), the proper until-material fix (no boolean trim).
      { id = gusset_sk, op = sketch, plane = XZ, open = true,
        entities = [
          { id = a, type = point, at = [ 3, 8 ] }
          { id = b, type = point, at = [ 22, 8 ] }
          { id = ln, type = line, p1 = a, p2 = b }
        ]
        constraints = [ { type = fix, of = a }, { type = fix, of = b } ] }
      { id = gusset, op = rib, profile = gusset_sk, target = ell, thickness = 5, until = true }
      # A datum plane 30mm up the wall for a mounting-hole reference (a real datum use).
      { id = mount_dp, op = datum_plane, method = offset, base = YZ, distance = 30 }
    ]
  }
}
