schema_version = 1
units = mm
metadata {
  description = "Slotted tab"
  tags = [ g1_2, part ]
}
# One part built from two curved sketches: a slot-shaped plate (the slot sugar lowers to
# 2 lines + 2 semicircular arc caps, an exact stadium) with a round hole pocketed through
# it (a first-class circle entity dimensioned by a radius constraint). Each sketch is a
# single closed loop; the circle is subtracted from the slot, so the result is one body.
parameters { slot_len = 60, slot_w = 24, hole_d = 10, t = 8 }
parts {
  slotted_tab {
    profile = solid
    features = [
      { id = slot_sk, op = sketch, plane = XY,
        entities = [
          { id = a, type = point, at = [ 0, 0 ] }
          { id = b, type = point, at = [ 60, 0 ] }
          { id = sl, type = slot, p1 = a, p2 = b, width = "${slot_w}" }
        ]
        constraints = [ { type = distance, points = [ a, b ], value = "${slot_len}" } ] }
      { id = plate, op = extrude, profile = slot_sk, distance = "${t}" }
      { id = hole_sk, op = sketch, plane = XY,
        entities = [
          { id = hc, type = point, at = [ 30, 0 ] }
          { id = c0, type = circle, center = hc, radius = 5 }
        ]
        constraints = [ { type = radius, of = c0, value = "${hole_d} / 2" } ] }
      { id = drill, op = pocket, target = plate, profile = hole_sk, distance = "${t}" }
    ]
  }
}
