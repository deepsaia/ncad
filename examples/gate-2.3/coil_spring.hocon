units = mm
metadata {
  description = "Coil spring"
  tags = [ g2_3, part ]
}
# A coil spring: a circular wire profile swept along a generated helix (pitch/height/radius
# about Z). Helical sweep; builds and round-trips to STEP.
parts {
  coil_spring {
    profile = solid
    features = [
      { id = wire_sk, op = sketch, plane = XZ,
        elements = [ { id = c, type = circle, d = 3 } ] }
      { id = coil, op = sweep, profile = wire_sk,
        helix = { pitch = 6, height = 40, radius = 12, axis = Z } }
    ]
  }
}
