schema_version = 2
units = mm
# A round pipe: a circular profile swept along a path with a ROUNDED (arc) corner. The arc
# joins the vertical rise to the horizontal run tangentially. Its center (5,15) is 5 from
# both legs, and it is authored start=c end=b so the CCW arc is the SHORT (minor) way, else
# WireOrderer's CCW-start->end rule would take the 270-degree major arc and curl it wrong.
# Single-path sweep; builds and round-trips to STEP (bucket 2.0).
parts {
  swept_pipe {
    profile = solid
    features = [
      { id = path_sk, op = sketch, plane = XZ, open = true,
        entities = [
          { id = a, type = point, at = [ 0, 0 ] }
          { id = b, type = point, at = [ 0, 15 ] }
          { id = ec, type = point, at = [ 5, 15 ] }
          { id = c, type = point, at = [ 5, 20 ] }
          { id = d, type = point, at = [ 20, 20 ] }
          { id = rise, type = line, p1 = a, p2 = b }
          { id = bend, type = arc, center = ec, start = c, end = b }
          { id = run, type = line, p1 = c, p2 = d }
        ]
        constraints = [ { type = fix, of = a }, { type = fix, of = b },
          { type = fix, of = ec }, { type = fix, of = c }, { type = fix, of = d } ] }
      { id = prof_sk, op = sketch, plane = XY,
        elements = [ { id = circ, type = circle, d = 4 } ] }
      { id = pipe, op = sweep, profile = prof_sk, path = path_sk }
    ]
  }
}
