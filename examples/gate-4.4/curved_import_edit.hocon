schema_version = 2
units = mm
# Import a foreign solid whose outline has a freeform (spline) side, then PROJECT that curved
# top edge into a new sketch as construction reference geometry and add a locating boss beside
# it. Exercises 4.4 curved-edge projection on IMPORTED geometry: the spline edge OCCT hands back
# is sampled into an interpolated construction spline (before 4.4 the kernel refused a spline
# edge, so no sketch could reference an imported freeform edge). The `file` is a STEP the
# accompanying test exports from our own kernel first (no committed binary; 4.0 reproducibility).
parts {
  curved_import_edit {
    profile = solid
    features = [
      { id = base, op = import, file = "out/curved_import_edit_input.step" }
      # Project the imported spline top edge (construction reference), and cut a locating slot on
      # the same face. The projected spline is reference geometry; the rectangle is the real cut.
      { id = scribe_sk, op = sketch, plane = XY, plane_offset = 8,
        project = [ "select edges where type='bspline' and min_z>7.9" ]
        entities = [
          { id = c0, type = point, at = [ 16, -13 ] }
          { id = c1, type = point, at = [ 24, -13 ] }
          { id = c2, type = point, at = [ 24, -7 ] }
          { id = c3, type = point, at = [ 16, -7 ] }
          { id = e0, type = line, p1 = c0, p2 = c1 }
          { id = e1, type = line, p1 = c1, p2 = c2 }
          { id = e2, type = line, p1 = c2, p2 = c3 }
          { id = e3, type = line, p1 = c3, p2 = c0 } ]
        constraints = [ { type = fix, of = c0 }, { type = fix, of = c1 },
          { type = fix, of = c2 }, { type = fix, of = c3 } ] }
      { id = slot_tool, op = extrude, profile = scribe_sk, distance = 4 }
      { id = grooved, op = boolean, operation = cut, target = base, tool = slot_tool }
    ]
  }
}
