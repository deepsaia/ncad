schema_version = 1
# A motion study with OUTPUTS (bucket 6.1): it drives the pump one flywheel revolution and, on top
# of the trajectory, emits motion outputs - a TRACE of the plunger crown's world path, a MEASURE of
# the plunger stroke (the crown's world-Y over time), and the SWEPT (displaced) VOLUME (the stroke
# travel x the bore area). Outputs are optional + additive: a motion doc without an `outputs` block
# just produces the trajectory (as the crank-slider / four-bar gates do). This is the single gate
# that exercises the 6.1 outputs.
metadata {
  description = "Reciprocating pump motion study: drive one revolution + emit trace/stroke/volume"
  tags = [ reciprocating_pump, motion, outputs ]
}
motion {
  assembly = "reciprocating_pump.asm.hocon"
  driver = { joint = mainPin, from = 0, to = 360, steps = 72 }
  outputs {
    traces = [
      { id = crownPath, instance = plunger, point = [ 0, 67, 0 ] }
    ]
    measures = [
      { id = stroke, kind = coordinate, instance = plunger, point = [ 0, 67, 0 ], axis = y }
      { id = displacement, kind = swept_volume, of = stroke, bore_d = 28 }
    ]
  }
}
