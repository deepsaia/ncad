units = mm
metadata {
  description = "Hex bolt"
  tags = [ dress-up, part ]
}
# An M10 hex bolt: a hexagonal head, a cylindrical shank, and an M10 thread callout over the
# shank. A real, recognizable fastener that exercises the 2.10 thread op (COSMETIC by default,
# like NX/Creo/Fusion: a callout recorded as metadata, no heavy helical geometry) + the
# ANSI/imperial hole-sizing table (M10 coarse pitch 1.5). A modeled real-helix thread is an
# explicit opt-in (`modeled = true`) shown on a clean stud in `threaded_stud.hocon`.
parts {
  hex_bolt {
    profile = solid
    material = steel_1018
    features = [
      # Hex head: a 6-sided polygon (across-flats ~16mm -> r 9.2) extruded 7mm.
      { id = head_sk, op = sketch, plane = XY,
        elements = [ { id = hex, type = polygon, sides = 6, r = 9.2 } ] }
      { id = head, op = extrude, profile = head_sk, distance = 7 }
      # Shank: a d10 cylinder growing up from the head top (plane_offset 7), 30mm long.
      { id = shank_sk, op = sketch, plane = XY, plane_offset = 7,
        elements = [ { id = c, type = circle, d = 10 } ] }
      { id = shank_ext, op = extrude, profile = shank_sk, distance = 30 }
      { id = bolt, op = boolean, operation = union, target = head, tool = shank_ext }
      # Cosmetic M10 thread callout over the shank (the professional default: metadata, no
      # geometry change).
      { id = thread, op = thread, size = M10 }
    ]
  }
}
