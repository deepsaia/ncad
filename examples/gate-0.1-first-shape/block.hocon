# Bucket 0.1 demo: a rectangle sketched on XY, extruded into a block.
units = mm
metadata {
  description = "Block"
  tags = [ g0_1-first-shape, part ]
}
parts {
  block {
    profile = solid
    features = [
      {
        id = sk
        op = sketch
        plane = XY
        elements = [ { id = r, type = rectangle, w = 80, h = 60 } ]
      }
      { id = pad, op = extrude, profile = sk, distance = 8 }
    ]
  }
}
