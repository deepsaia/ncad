units = mm
metadata {
  description = "Two body clip"
  tags = [ g0_5, part ]
}
# A base plate with a raised rail unioned on, then a slot cut across the rail. The
# boolean names its target and tool; the pocket names the unioned body. Reordering any
# of these before its input is defined is rejected pre-build by the dependency validator.
parameters {
  plate = 60
  plate_t = 6
  rail_w = 12
  rail_h = 14
  slot_w = 5
}
parts {
  two_body_clip {
    profile = solid
    features = [
      { id = plate_sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = "${plate}", h = "${plate}" } ] }
      { id = plate_solid, op = extrude, profile = plate_sk, distance = "${plate_t}" }
      { id = rail_sk, op = sketch, plane = XY,
        elements = [ { id = rr, type = rectangle, w = "${rail_w}", h = "${plate}" } ] }
      { id = rail_solid, op = extrude, profile = rail_sk, distance = "${plate_t} + ${rail_h}" }
      { id = body, op = boolean, operation = union, target = plate_solid, tool = rail_solid }
      { id = slot_sk, op = sketch, plane = XY,
        elements = [ { id = sr, type = rectangle, w = "${plate}", h = "${slot_w}" } ] }
      { id = slot, op = pocket, target = body, profile = slot_sk,
        distance = "${plate_t} + ${rail_h}" }
    ]
  }
}
