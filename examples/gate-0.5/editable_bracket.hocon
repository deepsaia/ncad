schema_version = 1
units = mm
metadata {
  description = "Editable bracket"
  tags = [ g0_5, part ]
}
# Bucket 0.5 demo: edit `thickness` and only the dirty suffix rebuilds; the fillet's
# selector reference and the holes' generative `pad.cap(+Z)` reference both survive.
# Delete the `pad` feature and the dependents report failure by id, never silent garbage.
parameters {
  width = 80
  depth = 50
  thickness = 10
  hole_d = 6
}
parts {
  editable_bracket {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = "${width}", h = "${depth}" } ] }
      { id = pad, op = extrude, profile = sk, distance = "${thickness}" }
      { id = holes, op = hole, on = "pad.cap(+Z)", diameter = "${hole_d}",
        depth = "${thickness}",
        positions = [ [ -25, -15 ], [ 25, -15 ], [ -25, 15 ], [ 25, 15 ] ] }
      { id = rnd, op = fillet, radius = 4,
        edges = "select edges where created_by='pad' and orientation='vertical'" }
    ]
  }
}
