# Bucket 4.2b demo: import a dumb solid, then direct-edit it. The `file` is a STEP that the
# accompanying test exports from our own kernel first (4.0 reproducibility; no committed binary).
# This is how the design (4.1 section 10) expresses direct ops on an imported model: an `import`
# base feature with direct ops appended in the same feature tree.
schema_version = 2
units = mm
parts {
  imported_edit {
    profile = solid
    features = [
      { id = base, op = import, file = "out/imported_edit_input.step" }
      { id = grow, op = offset, distance = 1 }
    ]
  }
}
