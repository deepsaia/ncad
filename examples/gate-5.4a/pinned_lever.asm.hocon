# Bucket 5.4a demo: gate-5.2's successor. Instead of a rigid coincident+concentric MATE network,
# the lever is joined to the grounded bracket by a REVOLUTE joint (a pin), leaving one rotational
# DoF free about the shared axis. The joint carries a DoF signature [rot Z] that Phase 6 will drive.
schema_version = 1
units = mm
metadata {
  description = "Pinned lever assembly"
  tags = [ g5_4a, assembly ]
}
assembly {
  instances = [
    { id = base, file = "pinned_lever.hocon", part = bracket, lock = true }
    { id = arm, file = "pinned_lever.hocon", part = lever }
  ]
  joints = [
    { id = j1, type = revolute, between = [
      { instance = base, connector = pivot },
      { instance = arm, connector = hub } ] }
  ]
}
