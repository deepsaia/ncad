# Bucket 5.2 demo: gate-5.1's successor. Instead of a single connect snap, the lever is placed by a
# solved MATE NETWORK: concentric (hub onto the bracket's pivot axis) + coincident (lever bottom onto
# the bracket top). The bracket is grounded (lock = true); py-slvs solves the lever's pose so it sits
# coaxially on the bracket top. The constraint solver is bucket 5.2; DoF-bearing joints are 5.4.
schema_version = 1
units = mm
metadata {
  description = "Arm linkage assembly"
  tags = [ g5_2, assembly ]
}
assembly {
  instances = [
    { id = base, file = "arm_linkage.hocon", part = bracket, lock = true }
    { id = arm, file = "arm_linkage.hocon", part = lever }
  ]
  constraints = [
    { id = m1, type = concentric, between = [
      { instance = base, connector = pivot },
      { instance = arm, connector = hub } ] }
    { id = m2, type = coincident, between = [
      { instance = base, connector = top },
      { instance = arm, connector = bottom } ] }
  ]
}
