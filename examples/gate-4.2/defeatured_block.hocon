# Bucket 4.2 demo: a base block with a cylindrical boss unioned on top, then defeature the
# boss top face (a GREEN case: removing it heals the hole and shrinks the solid).
# Direct-edit-on-authored-geometry (direct-edit-on-import is bucket 4.3).
units = mm
metadata {
  description = "Defeatured block"
  tags = [ g4_2, part ]
}
parts {
  defeatured_block {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY, elements = [ { id = r, type = rectangle, w = 60, h = 40 } ] }
      { id = base, op = extrude, profile = sk, distance = 20 }
      { id = boss_sk, op = sketch, plane = XY, plane_offset = 20, elements = [ { id = c, type = circle, d = 16 } ] }
      { id = boss_solid, op = extrude, profile = boss_sk, distance = 10 }
      { id = boss, op = boolean, operation = union, target = base, tool = boss_solid }
      { id = df, op = defeature, face = "select faces where normal_z > 0.9 and mid_z > 25" }
    ]
  }
}
