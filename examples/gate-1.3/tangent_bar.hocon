units = mm
metadata {
  description = "Tangent bar"
  tags = [ g1_3, part ]
}
# A stadium bar whose arc caps are tangent to the straight top/bottom, fixed and
# dimensioned. A driven (reference) dimension measures the overall span without
# constraining it. Demonstrates tangent constraints + a driven dimension reading back.
parameters { length = 60, radius = 12 }
parts {
  tangent_bar {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        entities = [
          { id = cl, type = point, at = [ 0, 0 ] }
          { id = cr, type = point, at = [ 60, 0 ] }
          { id = bl, type = point, at = [ 0, -12 ] }
          { id = br, type = point, at = [ 60, -12 ] }
          { id = tl, type = point, at = [ 0, 12 ] }
          { id = tr, type = point, at = [ 60, 12 ] }
          { id = bottom, type = line, p1 = bl, p2 = br }
          { id = top, type = line, p1 = tr, p2 = tl }
          { id = right_cap, type = arc, center = cr, start = br, end = tr }
          { id = left_cap, type = arc, center = cl, start = tl, end = bl }
        ]
        constraints = [
          { type = fix, of = cl }
          { type = horizontal, of = bottom }
          { type = distance, points = [ cl, cr ], value = "${length}" }
          { type = radius, of = left_cap, value = "${radius}" }
          { type = radius, of = right_cap, value = "${radius}" }
          { type = tangent, of = [ left_cap, bottom ] }
          { type = tangent, of = [ right_cap, bottom ] }
          { type = distance, points = [ bl, br ], driven = true, id = span }
        ] }
      { id = pad, op = extrude, profile = sk, distance = 8 }
    ]
  }
}
