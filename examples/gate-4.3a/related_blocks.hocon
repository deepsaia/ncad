# Bucket 4.3a demo: a block whose top face is asked to be coplanar with itself (already
# satisfied), exercising the relate op in the feature tree. Real two-body relational behavior
# (moving one block onto another) is covered by tests/ops/test_relational_real.py, since a
# two-body moving relation needs multibody addressing deferred past 4.3a.
units = mm
metadata {
  description = "Related blocks"
  tags = [ g4_3a, part ]
}
parts {
  related_blocks {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY, elements = [ { id = r, type = rectangle, w = 30, h = 30 } ] }
      { id = base, op = extrude, profile = sk, distance = 15 }
      { id = rel, op = relate, relation = coplanar, reference = "select faces where normal_z > 0.9", moving = "select faces where normal_z > 0.9" }
    ]
  }
}
