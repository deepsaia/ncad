schema_version = 1
units = mm
metadata {
  description = "Projected inset"
  tags = [ g1_4, part ]
}
# Reference-into-sketch on a round boss: a cylindrical post, then a sketch that projects
# the post's top circular edge and offsets it OUTWARD to make a wider base flange, which
# is extruded a little. Shows projecting a curved edge and offsetting it the other way
# (outset). A circle offset is self-closing, so no corner handling is needed.
parameters { post_d = 24, post_h = 20, flange = 10, flange_h = 5 }
parts {
  projected_inset {
    profile = solid
    features = [
      { id = post_sk, op = sketch, plane = XY,
        entities = [ { id = cp, type = point, at = [ 0, 0 ] },
          { id = c0, type = circle, center = cp, radius = 12 } ]
        constraints = [ { type = fix, of = cp },
          { type = radius, of = c0, value = "${post_d} / 2" } ] }
      { id = post, op = extrude, profile = post_sk, distance = "${post_h}" }
      { id = flange_sk, op = sketch, plane = XY,
        project = [ "select edges where created_by='post' and type='circle' and min_z<5" ],
        entities = [ { id = outer, type = offset, from = "proj/0", distance = "${flange}" } ]
        constraints = [] }
      { id = flange_solid, op = extrude, profile = flange_sk, distance = "${flange_h}" }
    ]
  }
}
