units = mm
metadata {
  description = "Two distance chamfer"
  tags = [ g2_6, part ]
}
# A block with an ASYMMETRIC (two-distance) chamfer on its vertical edges: 3 along one
# face, 6 along the other. Round-trips to STEP (bucket 2.0).
parts {
  two_distance_chamfer {
    profile = solid
    features = [
      { id = base_sk, op = sketch, plane = XY,
        elements = [ { id = sq, type = rectangle, w = 40, h = 40 } ] }
      { id = block, op = extrude, profile = base_sk, distance = 30 }
      { id = bevel, op = chamfer, edges = vertical, distance = 3, distance2 = 6 }
    ]
  }
}
