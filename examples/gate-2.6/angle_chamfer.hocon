units = mm
metadata {
  description = "Angle chamfer"
  tags = [ g2_6, part ]
}
# A block with a DISTANCE-ANGLE chamfer on its vertical edges: 4 setback at 30 degrees
# from an auto-picked adjacent face (built via raw OCP AddDA). Round-trips to STEP.
parts {
  angle_chamfer {
    profile = solid
    features = [
      { id = base_sk, op = sketch, plane = XY,
        elements = [ { id = sq, type = rectangle, w = 40, h = 40 } ] }
      { id = block, op = extrude, profile = base_sk, distance = 30 }
      { id = bevel, op = chamfer, edges = vertical, distance = 4, angle = 30 }
    ]
  }
}
