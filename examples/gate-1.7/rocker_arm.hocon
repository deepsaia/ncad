units = mm
# Bucket 1.7 gate: a symmetric rocker arm (a lever pivoting about a central hole), whose profile
# is fully constrained (dof 0) using the new sketch-solver constraints:
#   - symmetric_h: the outline mirrors about the horizontal centerline (top/bottom point pairs).
#   - length_ratio: the right arm is 2x the left arm (rightTop = 2 * leftTop).
#   - point_line_distance: the pivot sits 8 mm below the top edge (half the bar height).
#   - a solver-flexible 4-control-point bezier: the rounded right end, tangent to the top edge
#     (the tangent constraint drives the free control point bc1 onto the top line, y = 8).
#   - points_vertical / collinear: square ends + a straight top split at the pivot.
# The bar is extruded 6 mm and pierced by a pivot hole. A real, recognizable lever.
metadata {
  description = "Symmetric rocker arm: 2:1 lever, flexible bezier end blend, pivot hole"
  tags = [ g1_7, lever, sketch-constraints ]
}
parts {
  rocker_arm {
    profile = solid
    features = [
      { id = sk, op = sketch, plane = XY,
        entities = [
          { id = lt, type = point, at = [ -30, 8 ] }
          { id = mt, type = point, at = [ 0, 8 ] }
          { id = re, type = point, at = [ 60, 8 ] }
          { id = bc1, type = point, at = [ 68, 8 ] }
          { id = bc2, type = point, at = [ 72, -4 ] }
          { id = rb, type = point, at = [ 60, -8 ] }
          { id = lb, type = point, at = [ -30, -8 ] }
          { id = piv, type = point, at = [ 0, 0 ] }
          { id = leftTop, type = line, p1 = lt, p2 = mt }
          { id = rightTop, type = line, p1 = mt, p2 = re }
          { id = blend, type = bezier, points = [ re, bc1, bc2, rb ] }
          { id = bot, type = line, p1 = rb, p2 = lb }
          { id = left, type = line, p1 = lb, p2 = lt }
        ]
        constraints = [
          { type = fix, of = piv }
          { type = collinear, lines = [ leftTop, rightTop ] }
          { type = horizontal, of = leftTop }
          { type = points_vertical, points = [ mt, piv ] }
          { type = symmetric_h, points = [ lt, lb ] }
          { type = symmetric_h, points = [ re, rb ] }
          { type = points_vertical, points = [ lt, lb ] }
          { type = points_vertical, points = [ re, rb ] }
          { type = point_line_distance, point = piv, of = leftTop, value = 8 }
          { type = distance, points = [ lt, mt ], value = 30 }
          { type = length_ratio, lines = [ rightTop, leftTop ], value = 2.0 }
          { type = fix, of = bc2 }
          { type = tangent, of = [ blend, rightTop ] }
          { type = distance, points = [ re, bc1 ], value = 8 }
        ] }
      { id = pad, op = extrude, profile = sk, distance = 6 }
      { id = pivot, op = hole, plane = XY, positions = [ [ 0, 0 ] ], diameter = 10, through = true }
    ]
  }
}
