units = mm
metadata {
  description = "Nameplate"
  tags = [ g1_6, part ]
}
# A machine nameplate: a rectangular plate with the raised text "NCAD" standing proud of its
# face. A real, recognizable part that proves the 1.6 text sketch profile end to end:
#   - the plate is a plain rectangle extruded 2mm.
#   - the label is a `text` sketch element on the top face (plane_offset 2), extruded 1mm and
#     unioned on. The glyph counters (the holes in A, D) are real inner loops (multi-loop
#     faces), so the raised text reads correctly and round-trips to STEP.
parts {
  nameplate {
    profile = solid
    material = aluminium_6061
    features = [
      { id = plate_sk, op = sketch, plane = XY,
        elements = [ { id = r, type = rectangle, w = 80, h = 24 } ] }
      { id = plate, op = extrude, profile = plate_sk, distance = 2 }
      { id = label_sk, op = sketch, plane = XY, plane_offset = 2,
        elements = [ { id = t, type = text, text = "NCAD", font_size = 12,
                       at = [ -22, -6 ] } ] }
      { id = label, op = extrude, profile = label_sk, distance = 1 }
      { id = engraved, op = boolean, operation = union, target = plate, tool = label }
    ]
  }
}
