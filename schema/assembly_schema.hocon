# ncad assembly-document schema (HOCON): JSON-Schema draft 2020-12 vocabulary.
# An assembly is instances of parts (by file + part name) with optional explicit placement.
# Permissive while young: no additionalProperties=false, so the model grows (mates/joints later).

definitions {
  vec3 {
    type = array
    items { type = number }
    minItems = 3
    maxItems = 3
  }

  # A rigid placement: a position plus an optional rotation (axis-angle or euler).
  placement {
    type = object
    properties {
      position = ${definitions.vec3}
      rotation { type = object }
    }
  }

  # A connector-to-connector snap: place this instance so its `my` connector coincides with a
  # target instance's connector, with an optional axial offset and a face-opposing flip (bucket 5.1).
  connect {
    type = object
    required = ["my", "to"]
    properties {
      my { type = string }
      to {
        type = object
        required = ["instance", "connector"]
        properties {
          instance { type = string }
          connector { type = string }
        }
      }
      offset { type = number }
      flip { type = boolean }
    }
  }

  # A mate connector reference: which connector on which instance.
  mate_ref {
    type = object
    required = ["instance", "connector"]
    properties {
      instance { type = string }
      connector { type = string }
    }
  }

  # An assembly constraint (mate): a typed relation between one or two connector references
  # (bucket 5.2). Lowered to the normal-form primitive core and solved by py-slvs.
  mate {
    type = object
    required = ["id", "type", "between"]
    properties {
      id { type = string }
      type { enum = ["coincident", "mate", "flush", "align", "concentric", "parallel",
                     "perpendicular", "angle", "distance", "offset", "lock",
                     "tangent", "symmetric", "width"] }
      # up to THREE refs: symmetric/width use the third as the 'about' / second bounding plane.
      between {
        type = array
        minItems = 1
        maxItems = 3
        items = ${definitions.mate_ref}
      }
      value { type = number }
      flip { type = boolean }
    }
  }

  # A DoF-bearing joint (bucket 5.4a): positions two connectors while leaving a specific DoF free,
  # carrying a declared DoF signature. Lowers to the same primitive core as a mate.
  joint {
    type = object
    required = ["id", "type", "between"]
    properties {
      id { type = string }
      type { enum = ["fixed", "revolute", "slider", "cylindrical", "planar", "ball",
                     "point_on_line", "slot", "screw"] }
      between {
        type = array
        minItems = 2
        maxItems = 2
        items = ${definitions.mate_ref}
      }
      value {}
      limits {}
      pitch { type = number }
    }
  }

  # A declarative coupling between two joints (bucket 5.4b), enforced during motion (Phase 6).
  coupling {
    type = object
    required = ["id", "type", "between"]
    properties {
      id { type = string }
      type { enum = ["gear", "belt", "rack_pinion", "universal", "cam"] }
      between {
        type = array
        minItems = 2
        maxItems = 2
        items { type = string }
      }
      ratio { type = number }
      # A cam coupling's profile: a structured cam object that CamProfile turns into the follower's
      # prescribed lift. Two forms: the legacy single law ({law = harmonic|sine, base_r, lift,
      # lobes}), or the general segmented schedule ({base_r, segments = [{kind = dwell|rise|return,
      # law, angle, lift}]}) for a real engine-style dwell-rise-return cam. A string (a selector /
      # persistent-name curve ref on the cam part, for a future curved-contact solve) is also
      # accepted; the object form is what the motion pass enforces today.
      profile { oneOf = [ { type = string }, { type = object } ] }
    }
  }

  # One placed part instance: a reference to {file, part} plus a unique id and optional placement
  # (explicit) or connect (connector-driven snap). `lock` grounds the instance in the solve.
  instance {
    type = object
    # Only `id` is required: an instance is a part ({file, part}), a sub-assembly (`assembly`), or
    # a `mirror`/`replace` of another instance (bucket 5.7). The builder validates the combination.
    required = ["id"]
    properties {
      id { type = string }
      file { type = string }
      part { type = string }
      # A nested sub-assembly reference (a .asm.hocon path); recursively built + composed (5.7).
      assembly { type = string }
      placement = ${definitions.placement}
      connect = ${definitions.connect}
      lock { type = boolean }
      # A component pattern: array this instance's part at each placement (bucket 5.7). The
      # PatternParams vocabulary is the real gate; permissive here.
      pattern { type = object }
      # A component mirror: reflect an already-declared source instance (`of`) across a plane.
      mirror { type = object }
      of { type = string }
      # A component replace: swap the referenced {file, part} / assembly, keeping id + placement.
      replace { type = object }
    }
  }

  # Optional document metadata (extensible): a human description + freeform tags. Permissive so
  # more sub-keys can be added without a schema bump (matches the part schema).
  metadata {
    type = object
    properties {
      description { type = string }
      tags { type = array, items { type = string } }
    }
  }
}

type = object
required = ["schema_version", "units", "assembly"]
properties {
  schema_version { type = integer, minimum = 1 }
  units { enum = ["mm", "m", "in"] }
  metadata = ${definitions.metadata}
  assembly {
    type = object
    required = ["instances"]
    properties {
      instances {
        type = array
        items = ${definitions.instance}
      }
      constraints {
        type = array
        items = ${definitions.mate}
      }
      joints {
        type = array
        items = ${definitions.joint}
      }
      couplings {
        type = array
        items = ${definitions.coupling}
      }
    }
  }
}
