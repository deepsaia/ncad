# ncad feature-tree part schema (HOCON): JSON-Schema draft 2020-12 vocabulary.
#
# Authored in HOCON: comments, and DRY via ${...} substitution rather than $ref.
# Avoid every $-prefixed key ($schema/$id/$ref); HOCON's `$` is its substitution
# sigil. The validator loads this to a dict (via leaf-common) and hands it to
# jsonschema, which never reads the file itself.
#
# Units are declared per-document (mm | m | in); canonical internal unit is mm.
# Intentionally PERMISSIVE while young: no additionalProperties=false, so unknown
# fields pass and the schema grows without rejecting future documents. Only settled
# structural fields are constrained. Bump schema_version on incompatible changes.

definitions {
  # A 2D point (x, y).
  vec2 {
    type = array
    items { type = number }
    minItems = 2
    maxItems = 2
  }

  # A 3D point (x, y, z).
  vec3 {
    type = array
    items { type = number }
    minItems = 3
    maxItems = 3
  }

  # A sketch element. Bucket 0.1 supports the rectangle only; the enum grows later.
  sketch_element {
    type = object
    required = ["id", "type"]
    properties {
      id { type = string }
      type { enum = ["rectangle", "circle", "polygon", "text"] }
      w { type = number, exclusiveMinimum = 0 }
      h { type = number, exclusiveMinimum = 0 }
      d { type = number, exclusiveMinimum = 0 }
      r { type = number, exclusiveMinimum = 0 }
      sides { type = integer, minimum = 3 }
      points { type = array, items = ${definitions.vec2} }
      at = ${definitions.vec2}
      # A `text` element (an extrudable text profile): the glyph string + font controls.
      text { type = string }
      font_size { type = number, exclusiveMinimum = 0 }
      font { type = string }
      font_style { enum = ["regular", "bold", "italic"] }
      rotation { type = number }
    }
  }

  # One feature in a part's ordered feature tree. `op` selects the builder; the
  # remaining fields are op-specific and validated permissively here.
  feature {
    type = object
    required = ["id", "op"]
    properties {
      id { type = string }
      op { type = string }
      # plane is a base-plane string (sketch/shell/draft/mirror), a {point, normal} object
      # (mirror across an arbitrary plane), or a datum reference (a `datums.<id>` string that
      # resolves to a datum_plane feature). The pattern branch accepts the datum reference.
      plane { oneOf = [ { enum = ["XY", "XZ", "YZ"] }, { type = object },
                        { type = string, pattern = "^datums\\." } ] }
      plane_offset { type = number }
      elements {
        type = array
        items = ${definitions.sketch_element}
      }
      entities { type = array, items { type = object } }
      constraints { type = array, items { type = object } }
      profile { type = string }
      distance { type = number, exclusiveMinimum = 0 }
      positions { type = array, items = ${definitions.vec2} }
      diameter { type = number, exclusiveMinimum = 0 }
      depth { type = number, exclusiveMinimum = 0 }
      thickness { type = number, exclusiveMinimum = 0 }
      # rib options: until = grow to material (until-material extent), side = thickness mode,
      # profiles = a web (multi-blade) rib's profile references (in addition to a single profile).
      until { type = boolean }
      side { enum = ["both", "one"] }
      profiles { type = array, items { type = string } }
      # draft = wall taper angle (degrees) for a rib blade.
      draft { type = number }
      # Variable draft: per-face taper angles (parallel to the resolved faces). Per-face shell
      # thicknesses (unsupported; refused with a clear message).
      angles { type = array, items { type = number } }
      thicknesses { type = object }
      distance2 { type = number, exclusiveMinimum = 0 }
      angle { type = number }
      openings { type = string }
      # faces is a selector string (shell/draft) or a list of face references (face fillet);
      # vertices is a list of references whose corner vertices a vertex chamfer bevels.
      faces { type = ["string", "array"] }
      vertices { type = array, items { type = string } }
      neutral { enum = ["XY", "XZ", "YZ"] }
      neutral_offset { type = number }
      size { type = string }
      fit { enum = ["close", "normal", "loose", "tapped"] }
      # Modeled thread (thread op): crest diameter + pitch (or from `size`), thread `length`
      # along the axis, and internal (a tapped bore) vs external (a stud).
      major_d { type = number, exclusiveMinimum = 0 }
      pitch { type = number, exclusiveMinimum = 0 }
      length { type = number, exclusiveMinimum = 0 }
      internal { type = boolean }
      # thread: modeled = cut real helical geometry (opt-in); default is a cosmetic callout.
      modeled { type = boolean }
      # wrap emboss height (an alias of depth for embossing raised text/profiles).
      height { type = number, exclusiveMinimum = 0 }
      counterbore { type = object }
      countersink { type = object }
      thread { type = string }
      text { type = string }
      font_size { type = number, exclusiveMinimum = 0 }
      font { type = string }
      font_style { enum = ["regular", "bold", "italic"] }
      mode { enum = ["emboss", "engrave"] }
      offset { type = array, items { type = number }, minItems = 2, maxItems = 2 }
      rotation { type = number }
      through { type = boolean }
      radius { type = number, exclusiveMinimum = 0 }
      # Variable-radius fillet: a radius that ramps from radius_start to radius_end per edge.
      radius_start { type = number, exclusiveMinimum = 0 }
      radius_end { type = number, exclusiveMinimum = 0 }
      edges { type = string }
      on { type = string }
      operation { enum = ["cut", "union", "intersect"] }
      merge { type = boolean }
      # keep is a boolean for mirror (keep original + reflection) and a string enum for split
      # (both/top/bottom); accept either.
      keep { type = ["boolean", "string"] }
      # scope is a body-id string or an ordered list of body ids (boolean scope mode).
      scope { type = ["string", "array"] }
      tools { type = array, items { type = string } }
      move = ${definitions.vec3}
      rotate { type = object }
      scale { type = ["number", "array"] }
      copy { type = boolean }
      target { type = string }
      tool { type = string }
      sections { type = array, items { type = string } }
      ruled { type = boolean }
      # loft/sweep guide (rail) curve references; closed = periodic loft (unsupported, refused).
      guides { type = array, items { type = string } }
      closed { type = boolean }
      start_point = ${definitions.vec3}
      end_point = ${definitions.vec3}
      kind { type = string }
      x { type = object }
      y { type = object }
      # axis is a string (revolve/groove: X/Y/Z) or an object (revolve {point,dir},
      # circular pattern {point,dir}); accept both so both ops validate.
      axis { type = ["string", "object"] }
      count { type = integer, minimum = 1 }
      # A per-feature material override (bodies this feature mints inherit it) + an optional
      # inline mat_data that deep-merges onto the referenced material record (bucket 3.5).
      material { type = string }
      mat_data { type = object }
      # Datum construction (datum_plane / datum_axis): a method + its args. `base` is a base
      # plane string or a datum/face reference; `datum_points` are [x,y,z] triples.
      method { enum = ["offset", "angled", "on_face", "three_point", "two_point", "edge",
                       "intersection", "normal_to_face"] }
      base { type = string }
      face { type = string }
      datum_points { type = array, items = ${definitions.vec3} }
      edge { type = string }
      at_point = ${definitions.vec3}
      planes { type = array, items { type = string } }
    }
  }

  # A named mate connector: a coordinate frame derived from a geometry reference.
  connector {
    type = object
    required = ["id", "at"]
    properties {
      id { type = string }
      at { type = string }
      offset = ${definitions.vec3}
      primary { type = string }
      secondary = ${definitions.vec3}
    }
  }

  # A part: a profile kind plus an ordered list of features.
  part {
    type = object
    required = ["profile", "features"]
    properties {
      profile { type = string }
      # The part's default material name (a body inherits it unless its feature overrides).
      material { type = string }
      # Named mate connectors: geometry-derived frames other assemblies snap to (bucket 5.1).
      connectors {
        type = array
        items = ${definitions.connector}
      }
      features {
        type = array
        items = ${definitions.feature}
      }
    }
  }
}

type = object
required = ["schema_version", "units", "parts"]
properties {
  schema_version { type = integer, minimum = 1 }
  units { enum = ["mm", "m", "in"] }
  parameters { type = object }
  datums { type = object }
  # A document-inline material library (name -> mat_data record) and/or an external
  # material-library file referenced by path; both resolved by MaterialLibrary (bucket 3.5).
  materials { type = object }
  materials_library { type = string }
  parts {
    type = object
    minProperties = 1
    additionalProperties = ${definitions.part}
  }
}
